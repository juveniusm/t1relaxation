  <AppDomains>
    <AppDomain>https://juveniusm.github.io</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Presentation"/>
  </Hosts>

  <DefaultSettings>
    <SourceLocation DefaultValue="https://juveniusm.github.io/t1relaxation/"/>
    <RequestedWidth>800</RequestedWidth>
    <RequestedHeight>500</RequestedHeight>
  </DefaultSettings>

  <Permissions>ReadWriteDocument</Permissions>
